---
import {
    buildListingHref,
    formatCategoryLabel,
    type PublicCategory,
} from "../lib/public-content";

interface Props {
    action?: string;
    categories: PublicCategory[];
    q?: string;
    selectedCategory?: string;
}

const {
    action = "/posts",
    categories,
    q = "",
    selectedCategory = "",
} = Astro.props;
---

<section class="soft-panel hero-panel rounded-[1.9rem] p-6 sm:p-7">
    <div
        class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between"
    >
        <div class="max-w-xl">
            <p class="section-kicker">Guide Finder</p>
            <p class="mt-3 max-w-lg text-[1.4rem] font-bold leading-[1.35] text-[var(--text)]">
                Built and written by OLP clannies on 774 server.
            </p>
            <a
                href="/posts/guild-rules-important-notes"
                class="action-button mt-4 inline-flex items-center gap-2 rounded-[1rem] px-4 py-2 text-sm font-extrabold uppercase tracking-[0.08em]"
            >
                Guild Rules and Notes
                <span aria-hidden="true">→</span>
            </a>
        </div>

        <form
            action={action}
            method="get"
            class="grid w-full gap-3 lg:max-w-3xl lg:grid-cols-[1.3fr_0.8fr_auto]"
        >
            <label class="sr-only" for="search-input">Search articles</label>
            <input
                id="search-input"
                type="search"
                name="q"
                value={q}
                placeholder="Search builds, factions, gear paths, and progression"
                class="rounded-[1rem] border-2 border-[#dab180] bg-[rgba(255,249,239,0.92)] px-5 py-2.5 text-base text-[var(--text)] outline-none ring-0 transition placeholder:text-[var(--muted)] focus:border-[var(--accent)]"
            />

            <label class="sr-only" for="category-select">Category</label>
            <select
                id="category-select"
                name="category"
                class="rounded-[1rem] border-2 border-[#dab180] bg-[rgba(255,249,239,0.92)] px-5 py-2.5 text-base text-[var(--text)] outline-none focus:border-[var(--accent)]"
            >
                <option value="">All categories</option>
                {
                    categories.map((category) => (
                        <option
                            value={category.slug}
                            selected={selectedCategory === category.slug}
                        >
                            {category.label}
                        </option>
                    ))
                }
            </select>

            <button
                type="submit"
                class="action-button rounded-[1rem] px-5 py-2.5 text-base font-semibold"
            >
                Search
            </button>
        </form>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
        <a
            href={action}
            class:list={[
                "rounded-[1rem] border px-4 py-1.5 text-[0.98rem] transition",
                !selectedCategory
                    ? "border-[#79bdf6] bg-[rgba(79,170,248,0.14)] text-[var(--text)]"
                    : "border-[#dab180] bg-[rgba(255,249,239,0.68)] text-[var(--muted)] hover:border-[var(--accent)] hover:bg-[rgba(79,170,248,0.08)]",
            ]}
        >
            All
        </a>
        {
            categories.map((category) => (
                <a
                    href={buildListingHref(action, {
                        q,
                        category: category.slug,
                    })}
                    class:list={[
                        "rounded-[1rem] border px-4 py-1.5 text-[0.98rem] transition",
                        selectedCategory === category.slug
                            ? "border-[#79bdf6] bg-[rgba(79,170,248,0.14)] text-[var(--text)]"
                            : "border-[#dab180] bg-[rgba(255,249,239,0.68)] text-[var(--muted)] hover:border-[var(--accent)] hover:bg-[rgba(79,170,248,0.08)]",
                    ]}
                >
                    {formatCategoryLabel(category.label)}{" "}
                    <span class="text-xs opacity-70">({category.count})</span>
                </a>
            ))
        }
    </div>
</section>
