---
import { buildListingHref, formatCategoryLabel, type PublicCategory } from "../lib/public-content";

interface Props {
  action?: string;
  categories: PublicCategory[];
  q?: string;
  selectedCategory?: string;
}

const {
  action = "/posts",
  categories,
  q = "",
  selectedCategory = ""
} = Astro.props;
---

<section class="soft-panel rounded-[2rem] p-5 sm:p-6">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-2xl">
      <p class="text-xs uppercase tracking-[0.35em] text-[var(--muted)]">Find what you need</p>
      <h2 class="mt-2 text-3xl font-semibold text-[var(--text)]">Search articles and filter by category</h2>
      <p class="mt-3 text-base leading-8 text-[var(--muted)]">
        Use the search bar for hero builds, progression breakpoints, and reference notes, then narrow by category.
      </p>
    </div>

    <form action={action} method="get" class="grid w-full gap-3 lg:max-w-3xl lg:grid-cols-[1.3fr_0.8fr_auto]">
      <label class="sr-only" for="search-input">Search articles</label>
      <input
        id="search-input"
        type="search"
        name="q"
        value={q}
        placeholder="Search builds, resources, factions, and progression"
        class="rounded-full border border-[var(--line)] bg-white/80 px-5 py-3 text-sm outline-none ring-0 transition placeholder:text-[var(--muted)] focus:border-[var(--accent)]"
      />

      <label class="sr-only" for="category-select">Category</label>
      <select
        id="category-select"
        name="category"
        class="rounded-full border border-[var(--line)] bg-white/80 px-5 py-3 text-sm outline-none focus:border-[var(--accent)]"
      >
        <option value="">All categories</option>
        {categories.map((category) => (
          <option value={category.slug} selected={selectedCategory === category.slug}>
            {category.label}
          </option>
        ))}
      </select>

      <button
        type="submit"
        class="rounded-full bg-[var(--forest)] px-6 py-3 text-sm font-semibold text-white transition hover:opacity-90"
      >
        Search
      </button>
    </form>
  </div>

  <div class="mt-5 flex flex-wrap gap-2">
    <a
      href={action}
      class:list={[
        "rounded-full border px-4 py-2 text-sm transition",
        !selectedCategory
          ? "border-[var(--accent)] bg-[var(--accent-soft)] text-[var(--accent-strong)]"
          : "border-[var(--line)] text-[var(--muted)] hover:border-[var(--accent)] hover:bg-white/60"
      ]}
    >
      All
    </a>
    {categories.map((category) => (
      <a
        href={buildListingHref(action, { q, category: category.slug })}
        class:list={[
          "rounded-full border px-4 py-2 text-sm transition",
          selectedCategory === category.slug
            ? "border-[var(--accent)] bg-[var(--accent-soft)] text-[var(--accent-strong)]"
            : "border-[var(--line)] text-[var(--muted)] hover:border-[var(--accent)] hover:bg-white/60"
        ]}
      >
        {formatCategoryLabel(category.label)} <span class="text-xs opacity-70">({category.count})</span>
      </a>
    ))}
  </div>
</section>
