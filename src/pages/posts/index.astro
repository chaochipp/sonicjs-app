---
import PostCard from "../../components/PostCard.astro";
import SearchPanel from "../../components/SearchPanel.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchPosts } from "../../lib/public-api";
import { buildListingHref, formatCategoryLabel } from "../../lib/public-content";

const q = Astro.url.searchParams.get("q") ?? "";
const category = Astro.url.searchParams.get("category") ?? "";
const page = Number(Astro.url.searchParams.get("page") ?? "1");

const response = await fetchPosts(Astro.url, { q, category, page, pageSize: 9 });
const { items, categories, pagination, filters } = response;

const previousHref =
  pagination.page > 1
    ? buildListingHref("/posts", { q: filters.q, category: filters.category, page: pagination.page - 1 })
    : null;
const nextHref =
  pagination.page < pagination.totalPages
    ? buildListingHref("/posts", { q: filters.q, category: filters.category, page: pagination.page + 1 })
    : null;
---

<BaseLayout
  title="TopHeroes Articles | Browse guides and references"
  description="Search and filter TopHeroes articles, build guides, progression tutorials, and reference content."
>
  <SiteHeader />

  <main class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    <SearchPanel action="/posts" categories={categories} q={filters.q} selectedCategory={filters.category} />

    <section class="soft-panel rounded-[1.4rem] px-5 py-4 text-sm text-[var(--muted)]">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <p>
        Showing {items.length} of {pagination.totalItems} article{pagination.totalItems === 1 ? "" : "s"}
        {filters.q ? ` for "${filters.q}"` : ""}
      </p>
      {filters.category && <p>Category: {formatCategoryLabel(filters.category)}</p>}
      </div>
    </section>

    {items.length > 0 ? (
      <section class="grid gap-5 lg:grid-cols-3">
        {items.map((post) => (
          <PostCard post={post} />
        ))}
      </section>
    ) : (
      <section class="soft-panel rounded-[1.75rem] px-6 py-10 text-center">
        <h2 class="text-3xl font-semibold text-[var(--text)]">No articles matched your search.</h2>
        <p class="mt-3 text-base text-[var(--muted)]">
          Try a broader keyword or switch to a different category.
        </p>
      </section>
    )}

    <nav class="flex items-center justify-between">
      <div>
        {previousHref && (
          <a
            href={previousHref}
            class="secondary-button rounded-xl px-5 py-3 text-sm font-semibold transition"
          >
            Newer results
          </a>
        )}
      </div>
      <p class="text-sm text-[var(--muted)]">
        Page {pagination.page} of {pagination.totalPages}
      </p>
      <div>
        {nextHref && (
          <a
            href={nextHref}
            class="action-button rounded-xl px-5 py-3 text-sm font-semibold transition"
          >
            Older results
          </a>
        )}
      </div>
    </nav>
  </main>
</BaseLayout>
