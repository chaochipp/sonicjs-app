---
import PostCard from "../../components/PostCard.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchPostBySlug } from "../../lib/public-api";
import { formatCategoryLabel } from "../../lib/public-content";

const slug = Astro.params.slug ?? "";
const response = await fetchPostBySlug(Astro.url, slug);

if (!response) {
  Astro.response.status = 404;
}

const post = response?.item;
const related = response?.related ?? [];
---

<BaseLayout
  title={post?.seoTitle ?? "Page not found | TopHeroes Hub"}
  description={post?.seoDescription ?? "The requested TopHeroes article could not be found."}
>
  <SiteHeader />

  <main class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-4 py-8 sm:px-6 lg:px-8">
    {post ? (
      <>
        <article class="soft-panel rounded-[2.5rem] px-6 py-8 sm:px-8 sm:py-10">
          <div class="mx-auto max-w-5xl">
            <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.25em] text-[var(--muted)]">
              <a href={`/categories/${post.categorySlug}`} class="rounded-full bg-[var(--accent-soft)] px-3 py-1 text-[var(--accent-strong)]">
                {formatCategoryLabel(post.category)}
              </a>
              <span>{post.publishedAtLabel}</span>
              <span>{post.author}</span>
            </div>

            <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-[1.02] text-[var(--text)] sm:text-6xl">{post.title}</h1>
            <p class="mt-5 max-w-3xl text-lg leading-9 text-[var(--muted)]">{post.excerpt}</p>

            <div class="prose-content mt-10" set:html={post.contentHtml} />
          </div>
        </article>

        {related.length > 0 && (
          <section class="space-y-5">
            <div>
              <p class="text-xs uppercase tracking-[0.35em] text-[var(--muted)]">Related reading</p>
              <h2 class="mt-2 text-3xl font-semibold text-[var(--text)]">More in {formatCategoryLabel(post.category)}</h2>
            </div>
            <div class="grid gap-5 lg:grid-cols-3">
              {related.map((entry) => (
                <PostCard post={entry} />
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <section class="soft-panel rounded-[2.5rem] px-8 py-12 text-center">
        <p class="text-xs uppercase tracking-[0.35em] text-[var(--muted)]">404</p>
        <h1 class="mt-3 text-5xl font-semibold text-[var(--text)]">That article is not here.</h1>
        <p class="mt-4 text-lg leading-8 text-[var(--muted)]">
          The guide may have moved, been unpublished, or the link may be incorrect.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href="/posts"
            class="rounded-full bg-[var(--accent)] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[var(--accent-strong)]"
          >
            Browse all articles
          </a>
          <a
            href="/"
            class="rounded-full border border-[var(--line)] px-6 py-3 text-sm font-semibold text-[var(--text)] transition hover:border-[var(--accent)] hover:bg-white/60"
          >
            Return home
          </a>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
