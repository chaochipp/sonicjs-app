---
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | TopHeroes Hub" description="The requested TopHeroes article could not be found.">
  <SiteHeader />

  <main class="mx-auto flex min-h-[60vh] w-full max-w-4xl flex-col items-center justify-center gap-6 px-4 py-16 text-center sm:px-6 lg:px-8">
    <div class="soft-panel hero-panel rounded-[2rem] px-8 py-12">
      <p class="section-kicker">404</p>
      <h1 class="mt-3 text-5xl font-semibold text-[var(--text)]">That article is not here.</h1>
      <p class="mt-4 max-w-xl text-lg leading-8 text-[var(--muted)]">
        The guide may have moved, been unpublished, or the link may be incorrect.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="/posts"
          class="action-button rounded-xl px-6 py-3 text-sm font-semibold transition"
        >
          Browse all articles
        </a>
        <a
          href="/"
          class="secondary-button rounded-xl px-6 py-3 text-sm font-semibold transition"
        >
          Return home
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
